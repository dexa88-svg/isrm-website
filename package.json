{
  "name": "isrm-website",
  "version": "1.0.0",
  "description": "Interactive Scooter Manuals for Repair",
  "scripts": {
    "test": "node scripts/validate-pages.js && jest",
    "test:coverage": "node scripts/validate-pages.js && jest --coverage",
    "generate-stats": "node scripts/generate-stats.js"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "scripts/**/*.js",
      "public/**/*.js",
      "!public/data/**"
    ]
  }
}
